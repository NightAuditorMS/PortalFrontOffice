{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Relatório Diário Front Office",
  "description": "Esquema de dados diário para o relatório do Front Office, compatível com exportação futura do Power Automate.",
  "type": "object",
  "properties": {
    "reportDate": {
      "type": "string",
      "format": "date",
      "description": "Data do relatório no formato ISO (YYYY-MM-DD)."
    },
    "occupancy": {
      "type": "number",
      "description": "Percentual de ocupação do hotel." 
    },
    "totalRevenue": {
      "type": "number",
      "description": "Receita total do dia em euros." 
    },
    "revenue": {
      "type": "number",
      "description": "Alias para receita total, utilizado para compatibilidade com versões anteriores." 
    },
    "inHouse": {
      "type": "number",
      "description": "Número de hóspedes em house." 
    },
    "arrivals": {
      "type": "number",
      "description": "Número de chegadas previstas." 
    },
    "departures": {
      "type": "number",
      "description": "Número de saídas previstas." 
    },
    "roomServiceRevenue": {
      "type": "number",
      "description": "Receita do room service em euros." 
    },
    "restaurantRevenue": {
      "type": "number",
      "description": "Receita do restaurante em euros." 
    },
    "spaRevenue": {
      "type": "number",
      "description": "Receita do spa em euros." 
    },
    "averageRate": {
      "type": "number",
      "description": "Tarifa média diária (ADR) em euros." 
    },
    "vips": {
      "type": "array",
      "description": "Lista de chegadas VIP.",
      "items": {
        "type": "object",
        "properties": {
          "room": { "type": "string", "description": "Número do quarto do hóspede VIP." },
          "name": { "type": "string", "description": "Nome completo do hóspede VIP." },
          "pax": { "type": "integer", "description": "Número de ocupantes no quarto." },
          "arrival": { "type": "string", "description": "Data ou hora de chegada prevista." },
          "departure": { "type": "string", "description": "Data de partida prevista." }
        },
        "required": ["room", "name", "pax", "arrival", "departure"],
        "additionalProperties": false
      }
    },
    "events": {
      "type": "array",
      "description": "Lista de eventos agendados para o dia.",
      "items": {
        "type": "object",
        "properties": {
          "time": { "type": "string", "description": "Horário de início do evento (ex: HH:MM)." },
          "description": { "type": "string", "description": "Descrição sucinta do evento." },
          "location": { "type": "string", "description": "Local de realização do evento." }
        },
        "required": ["time", "description", "location"],
        "additionalProperties": false
      }
    },
    "oosRooms": {
      "type": "array",
      "description": "Lista de quartos fora de serviço (Out of Order).",
      "items": {
        "type": "object",
        "properties": {
          "roomNumber": { "type": "string", "description": "Número do quarto fora de serviço." },
          "reason": { "type": "string", "description": "Motivo do bloqueio / indisponibilidade." }
        },
        "required": ["roomNumber", "reason"],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "reportDate",
    "occupancy",
    "totalRevenue",
    "inHouse",
    "arrivals",
    "departures"
  ],
  "additionalProperties": true
}
